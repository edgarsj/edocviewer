---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  entry: CollectionEntry<'pages'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { locale, pageType, defaultViewerLocale } = entry.data;

const isMainPage = pageType === 'main';

// SEO footer links — locale-aware internal links for search engines
const footerLinks = locale === 'lv'
  ? [
      { label: 'Atvērt eDoc failu', href: '/lv/atvert-edoc-failu' },
      { label: 'ASiC-E Lasītājs', href: '/lv/asice-lasitajs' },
      { label: 'Kas ir eDoc?', href: '/lv/kas-ir-edoc' },
      { label: 'Salīdzināt skatītājus', href: '/lv/salidzinat-skatitajus' },
      { label: 'English', href: '/' },
    ]
  : [
      { label: 'Open eDoc File', href: '/open-edoc-file' },
      { label: 'ASiC-E Reader', href: '/asice-reader' },
      { label: 'What is eDoc?', href: '/what-is-edoc' },
      { label: 'Compare Viewers', href: '/compare-viewers' },
      { label: 'Latviešu', href: '/lv/' },
    ];
---

<BaseLayout entry={entry}>
  {isMainPage ? (
    <!-- Main page: edoc-app is the full UI, markdown is SEO-only -->
    <div id="static-content">
      <article class="container mx-auto px-4 py-8 prose prose-lg max-w-4xl">
        <Content />
      </article>
    </div>

    <edoc-app
      data-page-locale={locale}
      data-viewer-locale={defaultViewerLocale}
    ></edoc-app>
  ) : (
    <!-- Content page: Astro header + styled markdown + edoc-app -->
    <header class="bg-white border-b border-gray-200">
      <div class="container mx-auto px-4 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
          <a href={locale === 'lv' ? '/lv/' : '/'} class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <svg class="w-8 h-8 text-edoc-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12,12L16,16H13.5V19H10.5V16H8L12,12Z" />
            </svg>
            <span class="text-xl font-semibold text-gray-800">eDoc Viewer</span>
          </a>
        </div>
        <LanguageSwitcher entry={entry} />
      </div>
    </header>

    <main class="container mx-auto px-4 py-8">
      <article class="prose prose-lg max-w-4xl mx-auto mb-12">
        <Content />
      </article>

      <section class="max-w-6xl mx-auto mt-12">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <edoc-app
            embedded
            data-page-locale={locale}
            data-viewer-locale={defaultViewerLocale}
          ></edoc-app>
        </div>
      </section>
    </main>
  )}

  <!-- SEO footer links -->
  <footer class="text-center text-sm text-gray-500 py-6 mt-8 border-t border-gray-200">
    <nav class="flex flex-wrap justify-center gap-x-4 gap-y-1">
      {footerLinks.map((link, i) => (
        <a href={link.href} class="hover:text-edoc-700 transition-colors">{link.label}</a>
      ))}
    </nav>
  </footer>
</BaseLayout>
