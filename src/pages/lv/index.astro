---
import { getEntry } from 'astro:content';
import LandingLayout from '../../layouts/LandingLayout.astro';

// Get entry for Latvian index page (index.md files use folder name as ID)
const entry = await getEntry('pages', 'lv');

if (!entry) {
  throw new Error('Content entry not found: lv');
}
---

<LandingLayout entry={entry} />
