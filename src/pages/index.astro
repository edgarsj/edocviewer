---
import { getEntry } from 'astro:content';
import LandingLayout from '../layouts/LandingLayout.astro';

// Try both possible entry IDs (Astro handles index files differently)
let entry = await getEntry('pages', 'en/index');
if (!entry) {
  entry = await getEntry('pages', 'en');
}

if (!entry) {
  throw new Error('Content entry not found: en/index or en');
}
---

<LandingLayout entry={entry} />
