---
import { getEntry } from 'astro:content';
import LandingLayout from '../layouts/LandingLayout.astro';

// Get entry for English index page (index.md files use folder name as ID)
const entry = await getEntry('pages', 'en');

if (!entry) {
  throw new Error('Content entry not found: en');
}
---

<LandingLayout entry={entry} />
